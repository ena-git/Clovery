<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Clovery does not track users across apps or websites -->
	<key>NSPrivacyTracking</key>
	<false/>

	<!-- No tracking domains -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- All diary entries are stored locally on device only.
	     No user data is collected, transmitted, or shared. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- No APIs from Apple's required-reasons list are used directly -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array/>
</dict>
</plist>
